# Traan Environment Configuration
# Provide your actual API keys in a `.env.local` file - rename the file name

# Google Maps (Required for Deck.gl Tactical Maps)
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# Backend API base URL (Required for live data — set to your FastAPI server)
# Default: http://localhost:8000
# When not set, the dashboard falls back to mock data automatically.
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
